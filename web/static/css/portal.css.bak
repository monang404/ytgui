#portal-screen {
    display: none;
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at top right, #1e1e3f, #0d0d1a);
    z-index: 10000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
}

#portal-screen.portal-active {
    display: flex;
}

#app.portal-active {
    display: none !important;
}

.portal-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--fm-radius-xl);
    padding: 40px 30px;
    width: 100%;
    max-width: 440px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    animation: modalSlideUp 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.portal-title {
    font-size: 38px;
    font-weight: 800;
    background: linear-gradient(135deg, #ff7b93, #e94560, #ff8a7a);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
    text-shadow: 0 0 20px rgba(233, 69, 96, 0.2);
}

.portal-subtitle {
    color: var(--fm-text-5);
    font-size: 13px;
    margin-bottom: 35px;
}

.portal-options {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.portal-btn {
    width: 100%;
    padding: 20px;
    border-radius: var(--fm-radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--fm-text-1);
    text-align: left;
    cursor: pointer;
    transition: all var(--fm-transition-normal);
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    overflow: hidden;
}

.portal-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
    transform: translateX(-100%);
    transition: transform 500ms;
}

.portal-btn:hover::before {
    transform: translateX(100%);
}

.portal-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
}

.portal-btn .portal-icon {
    font-size: 24px;
    margin-bottom: 4px;
}

.portal-btn-title {
    font-size: 16px;
    font-weight: 700;
}

.portal-btn-desc {
    font-size: 11px;
    color: var(--fm-text-5);
    line-height: 1.4;
}

.portal-btn.client:hover {
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.1);
}

.portal-btn.admin:hover {
    border-color: rgba(233, 69, 96, 0.4);
    box-shadow: 0 0 15px rgba(233, 69, 96, 0.1);
}

/* Form Login Admin */
.portal-login-form {
    background: rgba(0, 0, 0, 0.2);
    border-radius: var(--fm-radius-md);
    padding: 16px;
    margin-top: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: fadeSlideIn 300ms ease forwards;
}

.portal-login-form.hidden {
    display: none;
}

.login-input-group {
    width: 100%;
}

.portal-login-form input {
    width: 100%;
    padding: 10px 14px;
    border-radius: var(--fm-radius-sm);
    border: 1.5px solid var(--fm-border);
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 13px;
    outline: none;
    transition: border-color var(--fm-transition-fast);
}

.portal-login-form input:focus {
    border-color: var(--fm-accent);
}

.portal-login-form button {
    width: 100%;
    padding: 10px;
    border-radius: var(--fm-radius-sm);
    border: none;
    background: var(--fm-accent);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--fm-transition-fast);
}

.portal-login-form button:hover {
    background: #d63051;
}

.login-error {
    color: var(--fm-err);
    font-size: 11px;
    font-weight: 500;
    text-align: center;
}

/* Logout Button */
.logout-btn {
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #fca5a5;
    padding: 6px 12px;
    border-radius: var(--fm-radius-sm);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--fm-transition-fast);
    display: flex;
    align-items: center;
    gap: 4px;
}

.logout-btn:hover {
    background: rgba(239, 68, 68, 0.25);
    border-color: rgba(239, 68, 68, 0.4);
}



